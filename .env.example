# Database Configuration
# Copy this file to .env and fill in your actual database credentials

# Database host (e.g., localhost, db.example.com)
DB_HOST=localhost

# Database port (default: 5432 for PostgreSQL)
DB_PORT=5432

# Database name
DB_NAME=mapex_tbt

# Database username
DB_USER=your_username

# Database password
DB_PASSWORD=your_password

# Database schema (optional, defaults to 'public')
DB_SCHEMA=public

API_KEY_GENESIS=
API_KEY_GOOGLE=
API_KEY_AMIGOALPHA=
API_KEY_HERE=
API_KEY_MAPBOX=
API_KEY_BING=
API_KEY_KAKAO=
API_KEY_GT=
API_KEY_MMI=
API_KEY_ZENRIN=
API_KEY_GENESYSMAP=