# Database Configuration
# Copy this file to .env and fill in your actual database credentials
# Connect to your existing PostgreSQL instance

# Database host - hostname or IP of your PostgreSQL server
# Examples: db.company.com, 192.168.1.100, localhost
DB_HOST=localhost

# Database port (default: 5432 for PostgreSQL)
DB_PORT=5432

# Database name
DB_NAME=mapex_tbt

# Database username
DB_USER=your_username

# Database password (CHANGE THIS!)
DB_PASSWORD=your_password

# Database schema (optional, defaults to 'public')
DB_SCHEMA=public

# Redis Configuration
# Connect to your existing Redis instance

# Redis host - hostname or IP of your Redis server
# Examples: redis.company.com, 192.168.1.101, localhost
REDIS_HOST=localhost

# Redis port (default: 6379)
REDIS_PORT=6379

# Redis password (optional, uncomment if your Redis requires authentication)
# REDIS_PASSWORD=your_redis_password

API_KEY_GENESIS=
API_KEY_GOOGLE=
API_KEY_AMIGOALPHA=
API_KEY_HERE=
API_KEY_MAPBOX=
API_KEY_BING=
API_KEY_KAKAO=
API_KEY_GT=
API_KEY_MMI=
API_KEY_ZENRIN=
API_KEY_GENESYSMAP=